{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug FreelanceExchange",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/freelance_exchange",
      "args": [],
      "stopAtEntry": true,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "setupCommands": [
        {
          "description": "Включить автоматическое форматирование для gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "preLaunchTask": "Build Debug",
      "miDebuggerPath": "/usr/bin/gdb",
      "linux": {
        "MIMode": "gdb"
      },
      "osx": {
        "MIMode": "lldb"
      },
      "windows": {
        "MIMode": "gdb",
        "miDebuggerPath": "gdb.exe"
      }
    }
  ]
}